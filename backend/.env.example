# .env is gitignored — never commit real secrets.

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ministry_complaints

JWT_SECRET=
JWT_EXPIRES_IN=8h
BCRYPT_COST=10

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
